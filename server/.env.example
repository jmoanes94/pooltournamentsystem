# Copy to `.env` in this folder (optional)
PORT=3001
# Comma-separated browser origins allowed to call this API (CORS + Socket.io). Add your Vercel URL, e.g.:
# CLIENT_ORIGIN=http://localhost:5173,https://your-app.vercel.app
CLIENT_ORIGIN=http://localhost:5173
# Set to true on the API host to allow any https://*.vercel.app preview (dev convenience; tighten for production if you prefer)
CORS_ALLOW_VERCEL_PREVIEW=false
ADMIN_PASSWORD=change-me
